# ============================================
# SmartShell Booking Notifier Bot — .env.example
# ============================================
# Скопируйте в .env и заполните свои значения
# cp .env.example .env

# ---------- SmartShell API ----------
SMARTSHELL_LOGIN=your_login
SMARTSHELL_PASSWORD=your_password
SMARTSHELL_COMPANY_ID=your_company_id
SMARTSHELL_HOST_IDS=host_id1,host_id2
SMARTSHELL_API_URL=https://api.smartshell.ru/graphql

# ---------- Telegram ----------
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ---------- Bitrix24 (опционально) ----------
# Если не нужен — закомментируйте или удалите
# BITRIX24_WEBHOOK_URL=https://portal.bitrix24.ru/rest/1/xxxxx/
# BITRIX24_BOT_CODE=smartshell_notifier
# BITRIX24_BOT_TOKEN=your_bot_token
# BITRIX24_DIALOG_ID=chat123

# ---------- Настройки бота ----------
CHECK_INTERVAL=60
LAST_ID_FILE=/app/data/last_booking_id.txt
STATUS_HISTORY_FILE=/app/data/status_history.json